[Unit]
Description=Anomaly Detector
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/home/ubuntu/detection-engine/detector
ExecStart=/home/ubuntu/detection-engine/.venv/bin/python /home/ubuntu/detection-engine/detector/main.py
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
